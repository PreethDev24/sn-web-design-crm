# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo mode — leave false for real integrations
NEXT_PUBLIC_DEMO_MODE=false
DEMO_MODE=false

# ─── Clerk (auth) ───────────────────────────────────────────
# Dashboard: https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: Clerk webhooks (user sync)
# Dashboard → Webhooks → endpoint: {APP_URL}/api/webhooks/clerk
# Events: user.created, user.updated, user.deleted
CLERK_WEBHOOK_SECRET=

# Optional but recommended: Clerk → Sessions → Customize session token
# Add: { "metadata": { "role": "{{user.public_metadata.role}}" } }

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/crm/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/crm/dashboard

# ─── Supabase (database + file storage) ─────────────────────
# Dashboard: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe (invoice payments) ──────────────────────────────
# Dashboard: https://dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Webhook: {APP_URL}/api/webhooks/stripe
# Event: checkout.session.completed
# Local: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# ─── Gmail (chat email notifications) ───────────────────────
# Send from your Gmail via SMTP + App Password (not your normal password).
# 1. Google Account → Security → 2-Step Verification (required)
# 2. Google Account → Security → App passwords → create one for "Mail"
# 3. Paste the 16-character app password below
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=
# Optional display/from override (defaults to GMAIL_USER)
# GMAIL_FROM=you@gmail.com

